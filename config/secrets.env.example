# ΜΗΝ ανεβάσεις αυτό το αρχείο στο GitHub
# Αντέγραψε σε secrets.env και συμπλήρωσε τα πραγματικά keys

# ── API KEYS ──────────────────────────────────────────────────────────────────
KUCOIN_API_KEY=your_kucoin_api_key
KUCOIN_API_SECRET=your_kucoin_api_secret
KUCOIN_API_PASSPHRASE=your_kucoin_passphrase

BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# ── TRADING SETTINGS ──────────────────────────────────────────────────────────
TRADING_PAIR=SOL/USDT
PROFIT_COIN=USDT
ACCOUNT_TYPE=margin

# ── BOT CORE ──────────────────────────────────────────────────────────────────
START_BASE_COIN=10
SCALE_BASE_COIN=4
RATIO_SCALE=0.005
BORROW_BASE_COIN=1

# ── BOT PROFIT (*) ────────────────────────────────────────────────────────────
MIN_PROFIT_PERCENT=10
STEP_POINT=0.5
TRAILING_STOP=2
LIMIT_ORDER=0.5

# ── SAFETY ────────────────────────────────────────────────────────────────────
MARGIN_LEVEL=1.07

# ── MODE: live / paper / backtest ─────────────────────────────────────────────
BOT_MODE=paper

# ── BACKTESTER ────────────────────────────────────────────────────────────────
BACKTEST_SYMBOL=SOL/USDT
BACKTEST_TIMEFRAME=1m
BACKTEST_START=2024-01-01
BACKTEST_END=2024-03-01

# ── LOGGING ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
